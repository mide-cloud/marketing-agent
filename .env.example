# Supabase — create a NEW project for this (or use same project, schema is isolated)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Auth — login credentials for the app
ADMIN_EMAIL=you@yourdomain.com
ADMIN_PASSWORD=choose-a-strong-password
JWT_SECRET=generate-a-random-64-char-string

# Encryption key for stored API keys and OAuth tokens
ENCRYPTION_KEY=generate-a-random-64-char-string

# Gmail OAuth — from Google Cloud Console (OAuth 2.0 Client ID, Web Application type)
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret

# Your deployed URL — used for tracking pixels and OAuth callback
# Local dev: http://localhost:3001
# Production: https://your-railway-app.up.railway.app
APP_URL=http://localhost:3001

PORT=3001
